<?xml version="1.0" encoding="UTF-8" ?>
<XMLDB PATH="local/ncasign/db" VERSION="2026070800" COMMENT="XMLDB file for local_ncasign"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="../../../lib/xmldb/xmldb.xsd"
>
  <TABLES>
    <TABLE NAME="local_ncasign_jobs" COMMENT="Signing jobs">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="courseid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="templateprofileid" TYPE="int" LENGTH="10" NOTNULL="false"/>
        <FIELD NAME="origin" TYPE="char" LENGTH="30" NOTNULL="true" DEFAULT="course_completion"/>
        <FIELD NAME="documentuuid" TYPE="char" LENGTH="36" NOTNULL="false"/>
        <FIELD NAME="documenttype" TYPE="char" LENGTH="20" NOTNULL="true" DEFAULT="certificate"/>
        <FIELD NAME="documenttitle" TYPE="char" LENGTH="255" NOTNULL="false"/>
        <FIELD NAME="drafthash" TYPE="char" LENGTH="64" NOTNULL="false"/>
        <FIELD NAME="finalhash" TYPE="char" LENGTH="64" NOTNULL="false"/>
        <FIELD NAME="finalizerbackend" TYPE="char" LENGTH="100" NOTNULL="false"/>
        <FIELD NAME="finalizationmanifest" TYPE="text" NOTNULL="false"/>
        <FIELD NAME="finalizationevidence" TYPE="text" NOTNULL="false"/>
        <FIELD NAME="certificateurl" TYPE="text" NOTNULL="false"/>
        <FIELD NAME="status" TYPE="char" LENGTH="20" NOTNULL="true" DEFAULT="pending_manual"/>
        <FIELD NAME="manualdeadline" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="manualcompleted" TYPE="int" LENGTH="10" NOTNULL="false"/>
        <FIELD NAME="autosigned" TYPE="int" LENGTH="10" NOTNULL="false"/>
        <FIELD NAME="autosignnote" TYPE="text" NOTNULL="false"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="userid_idx" UNIQUE="false" FIELDS="userid"/>
        <INDEX NAME="courseid_idx" UNIQUE="false" FIELDS="courseid"/>
        <INDEX NAME="origin_idx" UNIQUE="false" FIELDS="origin"/>
        <INDEX NAME="documentuuid_uix" UNIQUE="true" FIELDS="documentuuid"/>
        <INDEX NAME="status_idx" UNIQUE="false" FIELDS="status"/>
      </INDEXES>
    </TABLE>
    <TABLE NAME="local_ncasign_templates" COMMENT="Document template profiles">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="name" TYPE="char" LENGTH="255" NOTNULL="true" DEFAULT=""/>
        <FIELD NAME="renderer" TYPE="char" LENGTH="100" NOTNULL="true" DEFAULT=""/>
        <FIELD NAME="documenttype" TYPE="char" LENGTH="20" NOTNULL="true" DEFAULT="certificate"/>
        <FIELD NAME="documenttitle" TYPE="char" LENGTH="255" NOTNULL="false"/>
        <FIELD NAME="templatepath" TYPE="text" NOTNULL="false"/>
        <FIELD NAME="layoutconfig" TYPE="text" NOTNULL="false"/>
        <FIELD NAME="active" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="1"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="active_idx" UNIQUE="false" FIELDS="active"/>
      </INDEXES>
    </TABLE>
    <TABLE NAME="local_ncasign_number_counters" COMMENT="Daily generated document number counters">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="countertype" TYPE="char" LENGTH="20" NOTNULL="true"/>
        <FIELD NAME="counterdate" TYPE="char" LENGTH="8" NOTNULL="true"/>
        <FIELD NAME="currentvalue" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="counter_date_uix" UNIQUE="true" FIELDS="countertype, counterdate"/>
      </INDEXES>
    </TABLE>
    <TABLE NAME="local_ncasign_completion_suppress" COMMENT="Course completion events intentionally ignored by NCASign">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="courseid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="sourcecomponent" TYPE="char" LENGTH="100" NOTNULL="true" DEFAULT="local_sentaldocupload"/>
        <FIELD NAME="sourceid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="reason" TYPE="char" LENGTH="100" NOTNULL="true" DEFAULT="manual_course_completion_upload"/>
        <FIELD NAME="consumed" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="expiresat" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="timeconsumed" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="user_course_consumed_ix" UNIQUE="false" FIELDS="userid, courseid, consumed"/>
        <INDEX NAME="expiresat_ix" UNIQUE="false" FIELDS="expiresat"/>
      </INDEXES>
    </TABLE>
    <TABLE NAME="local_ncasign_template_courses" COMMENT="Course to template profile mappings">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="templateid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="courseid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="templateid_idx" UNIQUE="false" FIELDS="templateid"/>
        <INDEX NAME="courseid_idx" UNIQUE="false" FIELDS="courseid"/>
        <INDEX NAME="template_course_uix" UNIQUE="true" FIELDS="templateid, courseid"/>
      </INDEXES>
    </TABLE>
    <TABLE NAME="local_ncasign_template_signers" COMMENT="Signer sets per template profile">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="templateid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="signeremail" TYPE="char" LENGTH="255" NOTNULL="true" DEFAULT=""/>
        <FIELD NAME="signername" TYPE="char" LENGTH="255" NOTNULL="false"/>
        <FIELD NAME="signerposition" TYPE="char" LENGTH="255" NOTNULL="false"/>
        <FIELD NAME="expectediin" TYPE="char" LENGTH="12" NOTNULL="false"/>
        <FIELD NAME="signorder" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="1"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="templateid_idx" UNIQUE="false" FIELDS="templateid"/>
        <INDEX NAME="template_signorder_uix" UNIQUE="true" FIELDS="templateid, signorder"/>
      </INDEXES>
    </TABLE>
    <TABLE NAME="local_ncasign_signers" COMMENT="Signers assigned to jobs">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="jobid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="signerid" TYPE="int" LENGTH="10" NOTNULL="false"/>
        <FIELD NAME="signeremail" TYPE="char" LENGTH="255" NOTNULL="true" DEFAULT=""/>
        <FIELD NAME="signername" TYPE="char" LENGTH="255" NOTNULL="false"/>
        <FIELD NAME="signerposition" TYPE="char" LENGTH="255" NOTNULL="false"/>
        <FIELD NAME="expectediin" TYPE="char" LENGTH="12" NOTNULL="false"/>
        <FIELD NAME="signorder" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="1"/>
        <FIELD NAME="token" TYPE="char" LENGTH="64" NOTNULL="true" DEFAULT=""/>
        <FIELD NAME="status" TYPE="char" LENGTH="20" NOTNULL="true" DEFAULT="pending"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="notifiedat" TYPE="int" LENGTH="10" NOTNULL="false"/>
        <FIELD NAME="signedat" TYPE="int" LENGTH="10" NOTNULL="false"/>
        <FIELD NAME="signedby" TYPE="char" LENGTH="255" NOTNULL="false"/>
        <FIELD NAME="rawcms" TYPE="text" NOTNULL="false"/>
        <FIELD NAME="signercertificate" TYPE="text" NOTNULL="false"/>
        <FIELD NAME="signeriin" TYPE="char" LENGTH="12" NOTNULL="false"/>
        <FIELD NAME="ocspresponse" TYPE="text" NOTNULL="false"/>
        <FIELD NAME="signingmethod" TYPE="char" LENGTH="100" NOTNULL="false"/>
        <FIELD NAME="verificationstatus" TYPE="char" LENGTH="20" NOTNULL="false"/>
        <FIELD NAME="verificationinfo" TYPE="text" NOTNULL="false"/>
        <FIELD NAME="signmeta" TYPE="text" NOTNULL="false"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="jobid_idx" UNIQUE="false" FIELDS="jobid"/>
        <INDEX NAME="token_idx" UNIQUE="true" FIELDS="token"/>
        <INDEX NAME="status_idx" UNIQUE="false" FIELDS="status"/>
      </INDEXES>
    </TABLE>
  </TABLES>
</XMLDB>
